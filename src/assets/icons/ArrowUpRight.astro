---
interface Props {
  id?: string;
  size?: string | number;
  color?: string;
  class?: string;
  'stroke-width'?: string | number;
}
const {
  class: className,
  color = 'currentColor',
  size = '24',
  ...props
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={color}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...props}
>
  <path d="M7 7h10v10"></path><path d="M7 17 17 7"></path>
</svg>
