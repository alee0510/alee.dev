---
interface Props {
  styles?: {
    color?: string;
    border?: string;
    padding?: string;
    'background-color'?: string;
    'border-color'?: string;
    'border-width'?: string | number;
    'font-size'?: string | number;
    hover?: {
      color?: string;
      'background-color'?: string;
    };
  };
  icon?: boolean;
  class?: string;
}

const { styles = {}, icon = false, class: className, ...props } = Astro.props;

const variables = {
  '--button-fill': styles?.['background-color'] || '#ff542d',
  '--button-hover-fill': styles?.hover?.['background-color'] || '#ff8060',
  '--button-stroke': styles?.['border-color'] || '#7a2710',
  '--button-stroke-width': styles?.['border-width'] || '1',
  '--button-text-color': styles?.color || '#f0f0f0',
  '--button-hover-text-color': styles?.hover?.color || '#444',
  '--button-font-size': styles?.['font-size'] || '1rem',
  '--button-padding': styles?.padding || '0.5rem 1rem',
};
---

<div class=`button ${className}` style={variables} {...props}>
  <svg
    viewBox="0 0 340 56"
    preserveAspectRatio="none"
    class="button__bg"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      class="button__path"
      d="M 14,0 L 334,0 Q 340,0 340,6 L 340,39 Q 340,42 337,45 L 329,53 Q 326,56 323,56 L 6,56 Q 0,56 0,50 L 0,17 Q 0,14 3,11 L 11,3 Q 14,0 14,0 Z"
    ></path>
  </svg>
  <span class={`button__text ${icon && 'button__text--with-icon'}`}>
    <slot />
  </span>
</div>

<style>
  .button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--button-padding);
    cursor: pointer;
    isolation: isolate;
  }

  .button__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }

  .button__text {
    font-size: var(--button-font-size);
    color: var(--button-text-color);
    letter-spacing: 0.08rem;
    white-space: nowrap;
    text-align: center;
    line-height: 1;
    pointer-events: none;
    transition: color 0.3s ease;
  }

  .button__text--with-icon {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .button__path {
    fill: var(--button-fill);
    stroke: var(--button-stroke);
    stroke-width: var(--button-stroke-width);
    vector-effect: non-scaling-stroke;
    transition:
      fill 0.3s ease,
      stroke 0.3s ease;
  }

  .button:hover .button__path {
    fill: var(--button-hover-fill);
  }

  .button:hover .button__text {
    color: var(--button-hover-text-color);
  }
</style>
