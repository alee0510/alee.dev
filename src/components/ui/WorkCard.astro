---
import Image from 'astro/components/Image.astro';
import Sample from '@/assets/images/sample.jpg';
interface Props {
  class?: string;
  type: 'wide' | 'portrait';
}

const { class: className, type = 'wide', ...props } = Astro.props;
---

<div class={`work-card ${className}`} {...props}>
  <div class="work-card__thumbnail">
    <span class="work-card__tag work-card__tag--absolue">01. ROBOTIC CORE</span>
    <Image src={Sample} class="work-card__image" alt="work-card-image" />
  </div>
  <div class="work-card__desc">
    <h3
      class={`work-card__title ${type === 'wide' ? 'work-card__title--wide' : 'work-card__title--portrait'}`}
    >
      NEURO INTEFACE
    </h3>
    <p
      class={`work-card__summary ${type === 'wide' ? 'work-card__summary--wide' : 'work-card__summary--portrait'}`}
    >
      Developing low-latency neutral interface for next-generation automated
      surgical procedure.
    </p>
    <div
      class={`work-card__tags ${type === 'wide' ? 'work-card__tags--wide' : 'work-card__tags--portrait'}`}
    >
      <span class="work-card__tag">RUST</span>
      <span class="work-card__tag">WASP</span>
      <span class="work-card__tag">LLM</span>
      <span class="work-card__tag">NODE.JS</span>
    </div>
  </div>
</div>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    position: relative;
    padding: var(--space-sm);
  }

  .work-card::before {
    content: '';
    position: absolute;
    inset: 0px;
    --b: 2px;
    --c: 13px;
    background:
      conic-gradient(
          from 90deg at top var(--b) left var(--b),
          #0000 25%,
          var(--primary-400) 0
        )
        0 0 / var(--c) var(--c),
      conic-gradient(
          from 180deg at top var(--b) right var(--b),
          #0000 25%,
          var(--primary-400) 0
        )
        100% 0 / var(--c) var(--c),
      conic-gradient(
          from 0deg at bottom var(--b) left var(--b),
          #0000 25%,
          var(--primary-400) 0
        )
        0 100% / var(--c) var(--c),
      conic-gradient(
          from -90deg at bottom var(--b) right var(--b),
          #0000 25%,
          var(--primary-400) 0
        )
        100% 100% / var(--c) var(--c);
    background-repeat: no-repeat;
    opacity: 0;
    transition:
      opacity 0.3s ease,
      inset 0.3s ease;
    pointer-events: none;
  }

  .work-card:hover::before {
    opacity: 1;
    inset: -5px;
  }

  .work-card__thumbnail {
    position: relative;
  }

  .work-card__tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .work-card__tag {
    padding: var(--space-xs) var(--space-md);
    color: var(--neutral-700);
    font-size: var(--text-xs);
    background-color: var(--neutral-50);
  }

  .work-card__tag--absolue {
    position: absolute;
    top: 0;
    right: 0;
    transform: translate(-10px, 10px);
  }

  .work-card__image {
    width: 100%;
    height: 450px;
    object-fit: cover;
  }

  .work-card__title {
    color: var(--tertiary-900);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-block-end: 0;
  }

  .work-card__desc {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xs);
    font-size: var(--text-sm);
  }

  @media (width >= 768px) {
    .work-card__title {
      font-size: var(--text-2xl);
    }

    .work-card__desc {
      font-size: var(--text-base);
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-sm);
    }

    .work-card__image {
      height: 500px;
    }

    .work-card__tag {
      font-size: var(--text-sm);
      padding: var(--space-sm) var(--space-lg);
    }

    .work-card__title--wide {
      grid-column: 1 / 3;
    }

    .work-card__summary--wide {
      grid-column: 3 / 5;
    }

    .work-card__tags--wide {
      grid-column: 1 / 5;
    }

    .work-card__title--portrait,
    .work-card__summary--portrait,
    .work-card__tags--portrait {
      grid-column: 1 / 5;
    }
  }
</style>
