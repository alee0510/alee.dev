---
import Button from '@/components/ui/Button.astro';
import HumburgerMenu from '@/components/ui/HumburgerMenu.astro';
import MobileDrawer from './MobileDrawer.astro';
import type { Link } from '@/types';

const NavigationLinks: Link[] = [
  {
    id: '01',
    label: 'WORK',
    href: '/work',
  },
  {
    id: '02',
    label: 'BLOG',
    href: '/blog',
  },
  {
    id: '03',
    label: 'ABOUT',
    href: '/about',
  },
  {
    id: '04',
    label: 'HIRE ME',
    href: '/hire me',
  },
];
---

<header class="header">
  <nav class="nav" aria-label="Main navigation">
    <div class="nav__brand">@LEE.DEV/V1.0.1</div>

    <!-- Desktop Only -->
    <div class="nav__links" id="nav-links">
      {
        NavigationLinks.slice(0, 3).map((link, index) => {
          return (
            <a class={`nav__link ${link.id == '01' && 'nav__link--active'}`}>
              {link.label}
            </a>
          );
        })
      }
      <div class="nav__underline" id="nav-underline"></div>
    </div>
    <Button
      styles={{
        color: 'var(--tertiary-600)',
        padding: 'var(--space-md) var(--space-2xl)',
        'border-color': 'var(--primary-600)',
        'font-size': 'var(--text-lg)',
        hover: {
          'background-color': 'transparent',
        },
      }}
      class="nav__hire-me">HIRE ME</Button
    >

    <!-- Mobile Only -->
    <HumburgerMenu />
  </nav>
</header>

<MobileDrawer links={NavigationLinks} />

<style>
  .header {
    width: 100%;
    background: var(--neutral-80);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--gutter-sm) var(--gutter-md);
    margin: 0 auto;
    max-width: var(--screen-xl);
  }

  .nav__brand {
    font-size: var(--text-lg);
    font-weight: bold;
    letter-spacing: 0.04rem;
    color: var(--tertiary-600);
  }

  .nav__hire-me {
    display: none;
  }

  .nav__links {
    position: relative;
    display: none;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav__link {
    color: var(--secondary-600);
    padding: var(--space-xs) 0;
    letter-spacing: 0.08rem;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .nav__link--active {
    color: var(--primary-400);
  }

  .nav__underline {
    position: absolute;
    bottom: var(--space-n-xs);
    height: 2px;
    background: var(--primary-400);
    border-radius: 1px;
    pointer-events: none;
    transition:
      left 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      width 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (width >= 768px) {
    .nav {
      padding: var(--gutter-md) var(--gutter-2xl);
    }

    .nav__brand {
      font-size: var(--text-xl);
    }

    .nav__links {
      display: flex;
    }

    .nav__hire-me {
      display: inline-flex;
    }
  }
</style>

<script>
  const navLinks = document.getElementById('nav-links')!;
  const line = document.getElementById('nav-underline')!;
  const links = navLinks.querySelectorAll<HTMLElement>('.nav__link');

  function moveLine(el: HTMLElement) {
    const navRect = navLinks.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    line.style.left = elRect.left - navRect.left + 'px';
    line.style.width = elRect.width + 'px';
  }

  // Init: snap to active item without animating
  function init() {
    const active = navLinks.querySelector<HTMLElement>('.nav__link--active');
    if (!active) return;
    line.style.transition = 'none';
    moveLine(active);
    // Re-enable transition after one frame
    requestAnimationFrame(() => {
      line.style.transition = '';
    });
  }

  links.forEach((link) => {
    link.addEventListener('click', () => {
      links.forEach((l) => l.classList.remove('nav__link--active'));
      link.classList.add('nav__link--active');
      moveLine(link);
    });
  });

  init();
</script>
