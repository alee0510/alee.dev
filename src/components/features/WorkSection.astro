---
import WrokCard from '@/components/ui/WorkCard.astro';
---

<section id="selected-work" class="work">
  <div class="work__header">
    <p class="work__section">01&nbsp;/&nbsp;SELECTED WORK</p>
    <div class="work__title-container">
      <span class="work__title">CASE STUDIES</span>
      <span class="work__info"
        >SCROLL TO EXPLORE<span class="work__archive"
          >&nbsp;/&nbsp;ACHIEVE 2020-2026</span
        >
      </span>
    </div>
    <div class="work__contents">
      <WrokCard class="work--01" type="wide" />
      <WrokCard class="work--02" type="portrait" />
      <WrokCard class="work--03" type="portrait" />
      <WrokCard class="work--04" type="wide" />
    </div>
  </div>
</section>

<style>
  .work {
    margin: 0 auto;
    padding: var(--gutter-md) var(--gutter-lg);
    max-width: var(--screen-xl);
    background-color: var(--neutral-200);
  }

  .work__section {
    color: var(--primary-400);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .work__title-container {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .work__title {
    color: var(--tertiary-900);
    font-size: var(--text-xl);
    font-weight: 700;
  }

  .work__info {
    font-size: var(--text-xs);
    color: var(--neutral-700);
  }

  .work__archive {
    display: none;
  }

  .work__contents {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-block: var(--gutter-sm);
  }

  @media (width >= 768px) {
    .work {
      padding: var(--gutter-md) var(--gutter-xl);
    }

    .work__contents {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
      margin-block: var(--gutter-lg);
    }

    .work__section {
      font-size: var(--text-sm);
    }

    .work__title {
      font-size: var(--text-2xl);
    }

    .work__info {
      font-size: var(--text-sm);
    }

    .work__archive {
      display: inline-block;
    }

    .work--01 {
      grid-column: 1 / 3;
    }

    .work--02 {
      grid-column: 3 / 4;
    }

    .work--03 {
      grid-column: 1 / 2;
    }

    .work--04 {
      grid-column: 2 / 4;
    }
  }
</style>
