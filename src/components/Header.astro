---
import Button from './Button.astro';
---

<header class="header">
  <nav class="nav">
    <div class="nav__brand">@LEE.DEV/V1.0.1</div>
    <div class="nav__links" id="navLinks">
      <span class="nav__link nav__link--active">WORK</span>
      <span class="nav__link">BLOG</span>
      <span class="nav__link">ABOUT</span>
      <div class="nav__underline" id="underline"></div>
    </div>
    <Button
      text="HIRE ME"
      fill="var(--primary-400)"
      stroke="var(--primary-600)"
      strokeWidth="1"
      fontSize="var(--text-lg)"
      textColor="var(--tertiary-600)"
      hoverFill="transparent"
      hoverTextColor="var(--tertiary-600)"
      padding="var(--space-md) var(--space-xl)"
    />
  </nav>
</header>

<style>
  .header {
    width: 100%;
    background: var(--neutral-80);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--gutter-md) var(--gutter-2xl);
    margin: 0 auto;
    width: 100%;
    max-width: var(--screen-xl);
  }

  .nav__brand {
    font-size: var(--text-xl);
    font-weight: bold;
    letter-spacing: 0.04rem;
    color: var(--tertiary-600);
  }

  .nav__hire {
    padding: var(--space-md) var(--space-xl);
    font: var(--text-lg);
    border-radius: 1%;
  }

  .nav__links {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav__link {
    color: var(--secondary-600);
    padding: var(--space-xs) 0;
    letter-spacing: 0.08rem;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
  }

  .nav__link--active {
    color: var(--primary-400);
  }

  .nav__underline {
    position: absolute;
    bottom: var(--space-n-xs);
    height: 2px;
    background: var(--primary-400);
    border-radius: 1px;
    pointer-events: none;
    transition:
      left 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      width 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
</style>

<script>
  const navLinks = document.getElementById('navLinks')!;
  const line = document.getElementById('underline')!;
  const links = navLinks.querySelectorAll<HTMLElement>('.nav__link');

  function moveLine(el: HTMLElement) {
    const navRect = navLinks.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    line.style.left = elRect.left - navRect.left + 'px';
    line.style.width = elRect.width + 'px';
  }

  // Init: snap to active item without animating
  function init() {
    const active = navLinks.querySelector<HTMLElement>('.nav__link--active');
    if (!active) return;
    line.style.transition = 'none';
    moveLine(active);
    // Re-enable transition after one frame
    requestAnimationFrame(() => {
      line.style.transition = '';
    });
  }

  links.forEach((link) => {
    link.addEventListener('click', () => {
      links.forEach((l) => l.classList.remove('nav__link--active'));
      link.classList.add('nav__link--active');
      moveLine(link);
    });
  });

  init();
</script>
