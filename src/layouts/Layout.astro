---
import '@/styles/global.css';
import Header from '@/components/features/Header.astro';
import Footer from '@/components/features/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>@Lee.dev</title>
  </head>
  <body class="grid">
    <Header />
    <main class="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .grid {
    background-color: var(--neutral-100);
    background-image:
      linear-gradient(var(--neutral-200) 1px, transparent 1px),
      linear-gradient(90deg, var(--neutral-200) 1px, transparent 1px);
    background-size: var(--gutter-lg) var(--gutter-lg);
  }

  .main {
    margin-top: var(--gutter-3xl);
  }
</style>
